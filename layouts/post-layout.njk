<!DOCTYPE html>
<html class="avada-html-layout-wide avada-html-header-position-top avada-is-100-percent-template awb-scroll" lang="en-US">
<head>
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta http-equiv="Content-Type" content="text/html; charset=utf-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />

  <title>{{ seo_title if seo_title else title }} - Prism Dynamic Medical Supply Solutions</title>
  <meta name="description" content="{{ seo_description if seo_description else summary }}" />

  <meta property="og:locale" content="en_US"/>
  <meta property="og:type" content="article"/>
  <meta property="og:site_name" content="Prism Dynamic Medical Supply Solutions"/>
  <meta property="og:title" content="{{ seo_title if seo_title else title }}"/>
  <meta property="og:description" content="{{ seo_description if seo_description else summary }}"/>
  <meta property="og:url" content="{{ page.url }}"/>
  {% if image %}<meta property="og:image" content="{{ image }}"/>{% endif %}

  <link rel="shortcut icon" href="/images/uploads/2023/03/favicon.png" type="image/x-icon" />
  <link rel="apple-touch-icon" sizes="180x180" href="/images/uploads/2023/03/favicon.png">
  <link rel="icon" sizes="192x192" href="/images/uploads/2023/03/favicon.png">

  <link rel="stylesheet" href="/css/uploads/fusion-styles/a3b759c6fcd32db46bec077a7b4320ea.min3dab.css?ver=3.11.9" type="text/css" media="all" />
  <script type="text/javascript" src="/js/js/jquery/jquery.minf43b.js?ver=3.7.1"></script>

  <link rel="preload" href="/fonts/themes/Avada/includes/lib/assets/fonts/icomoon/awb-icons.woff" as="font" type="font/woff" crossorigin>
  <link rel="preload" href="/fonts/themes/Avada/includes/lib/assets/fonts/fontawesome/webfonts/fa-solid-900.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="preload" href="https://fonts.gstatic.com/s/muktamahee/v19/XRXQ3IOIi0hcP8iVU67hA9vKUT8.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="preload" href="https://fonts.gstatic.com/s/sortsmillgoudy/v16/Qw3GZR9MED_6PSuS_50nEaVrfzgEbHoEjw.woff2" as="font" type="font/woff2" crossorigin>

  <style type="text/css" id="css-fb-visibility">
    @media screen and (max-width: 640px){.fusion-no-small-visibility{display:none !important;}}
    @media screen and (min-width: 641px) and (max-width: 1024px){.fusion-no-medium-visibility{display:none !important;}}
    @media screen and (min-width: 1025px){.fusion-no-large-visibility{display:none !important;}}
  </style>

  <style type="text/css" id="wp-custom-css">
    .fusion-main-menu:not(.fusion-sticky-menu) { display: block !important; }
    .fusion-mobile-selector, .fusion-mobile-menu-icons { display: none !important; }

    .prism-post-single {
      max-width: 1331.2px;
      margin: 0 auto;
      padding: 30px 3.84%;
    }
    .prism-post-single h1 {
      color: #052c5c;
      font-family: "Sorts Mill Goudy", serif;
      font-size: 36px;
      font-weight: 400;
      margin-bottom: 10px;
      line-height: 1.2;
    }
    .prism-post-single h2 {
      color: #052c5c;
      font-family: "Mukta Mahee", sans-serif;
      font-size: 24px;
      font-weight: 600;
      margin: 24px 0 10px;
      text-transform: uppercase;
    }
    .prism-post-single h3 {
      color: #052c5c;
      font-family: "Mukta Mahee", sans-serif;
      font-size: 18px;
      font-weight: 600;
      margin: 16px 0 8px;
    }
    .prism-post-single p {
      color: #50586b;
      font-family: "Mukta Mahee", sans-serif;
      font-size: 16px;
      line-height: 1.7;
      margin-bottom: 16px;
    }
    .prism-post-single ul, .prism-post-single ol {
      color: #50586b;
      font-family: "Mukta Mahee", sans-serif;
      font-size: 16px;
      line-height: 1.7;
      padding-left: 24px;
      margin-bottom: 16px;
    }
    .prism-post-single a { color: #ea3f3d; }
    .prism-post-single img { max-width: 100%; height: auto; }
    .prism-post-hero { width: 100%; max-height: 420px; object-fit: cover; margin-bottom: 30px; }
    .prism-post-meta {
      color: #888;
      font-family: "Mukta Mahee", sans-serif;
      font-size: 14px;
      margin-bottom: 24px;
      display: flex;
      gap: 12px;
      align-items: center;
      flex-wrap: wrap;
    }
    .prism-post-category {
      background: #052c5c;
      color: #fff;
      padding: 3px 10px;
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 1px;
      font-family: "Mukta Mahee", sans-serif;
      font-weight: 600;
    }
    .prism-post-breadcrumb {
      padding: 14px 3.84%;
      max-width: 1331.2px;
      margin: 0 auto;
      font-family: "Mukta Mahee", sans-serif;
      font-size: 14px;
      color: #888;
      border-bottom: 1px solid #eee;
      margin-bottom: 10px;
    }
    .prism-post-breadcrumb a { color: #052c5c; text-decoration: none; }
    .prism-back-link {
      display: inline-block;
      margin-top: 40px;
      color: #052c5c;
      font-family: "Mukta Mahee", sans-serif;
      font-size: 14px;
      text-decoration: none;
      border: 1px solid #052c5c;
      padding: 8px 16px;
    }
    .prism-back-link:hover { background: #052c5c; color: #fff; }
  </style>

  <link rel="stylesheet" href="/css/common-preloader.css" type="text/css" media="all" />
  <script src="/js/cm-consent-guard.js"></script>
</head>

<body class="wp-singular single-post wp-theme-Avada wp-child-theme-Avada-child fusion-image-hovers fusion-button_type-flat fusion-button_span-no fusion-button_gradient-linear fusion-body ltr fusion-sticky-header no-tablet-sticky-header no-mobile-sticky-header no-mobile-slidingbar fusion-disable-outline fusion-sub-menu-fade mobile-logo-pos-left layout-wide-mode layout-scroll-offset-full avada-has-zero-margin-offset-top fusion-top-header menu-text-align-left mobile-menu-design-modern fusion-show-pagination-text fusion-header-layout-v3 avada-responsive avada-footer-fx-none avada-menu-highlight-style-bar fusion-search-form-clean fusion-main-menu-search-overlay fusion-sticky-shrinkage avada-dropdown-styles avada-header-shadow-no avada-menu-icon-position-left avada-has-mainmenu-dropdown-divider avada-has-main-nav-search-icon avada-has-breadcrumb-mobile-hidden avada-has-titlebar-hide avada-header-border-color-full-transparent avada-flyout-menu-direction-fade">

  <div class="preloader"></div>
  <a class="skip-link screen-reader-text" href="#content">Skip to content</a>

  <div id="boxed-wrapper">
    <div class="fusion-sides-frame"></div>
    <div id="wrapper" class="fusion-wrapper">
      <div id="home" style="position:relative;top:-1px;"></div>
      <div id="common-layout-header"></div>
      <div id="sliders-container" class="fusion-slider-visibility"></div>

      <section id="content" style="width:100%;">
        <div class="post-content">

          <div class="prism-post-breadcrumb">
            <a href="/team-prism-prism-post">Prism Post</a> &rsaquo; {{ title }}
          </div>

          <div class="prism-post-single">

            <h1>{{ title }}</h1>

            <div class="prism-post-meta">
              {% if category %}<span class="prism-post-category">{{ category }}</span>{% endif %}
              <span>{{ date | readableDate }}</span>
            </div>

            {% if image %}
            <img class="prism-post-hero" src="{{ image }}" alt="{{ title }}" />
            {% endif %}

            <div class="prism-post-body">
              {{ content | safe }}
            </div>

            <a class="prism-back-link" href="/team-prism-prism-post">&larr; Back to Prism Post</a>

          </div>

        </div>
      </section>

      <div id="common-layout-footer"></div>

    </div>
  </div>

  <section class="to-top-container to-top-right" aria-labelledby="awb-to-top-label">
    <a href="#" id="toTop" class="fusion-top-top-link">
      <span id="awb-to-top-label" class="screen-reader-text">Go to Top</span>
    </a>
  </section>

  <script type="text/javascript" src="/js/uploads/fusion-scripts/7c8487d4e3c0b74ce44025e6e9202bb2.min3dab.js?ver=3.11.9"></script>
  <script type="text/javascript" src="/js/common-layout.js"></script>
</body>
</html>
